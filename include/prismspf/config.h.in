#pragma once

// NOLINTBEGIN(cppcoreguidelines-macro-usage)

// Version numbers
#define PRISMS_PF_VERSION "@PRISMS_PF_VERSION@"
#define PRISMS_PF_VERSION_MAJOR @PRISMS_PF_VERSION_MAJOR @
#define PRISMS_PF_VERSION_MINOR @PRISMS_PF_VERSION_MINOR @
#define PRISMS_PF_VERSION_SUBMINOR @PRISMS_PF_VERSION_SUBMINOR @
#define PRISMS_PF_GIT_VERSION "@PRISMS_PF_GIT_REVISION@"

// Build information
#cmakedefine PRISMS_PF_64BIT_INDICES
#cmakedefine PRISMS_PF_THREADS
#cmakedefine PRISMS_PF_GPU

#cmakedefine PRISMS_PF_WITH_VTK
#cmakedefine PRISMS_PF_WITH_HDF5
#cmakedefine PRISMS_PF_WITH_CALIPER

#define PRISMS_PF_CXX_COMPILER "@CMAKE_CXX_COMPILER_ID@"
#define PRISMS_PF_CXX_COMPILER_VERSION "@CMAKE_CXX_COMPILER_VERSION@"
#define PRISMS_PF_CXX_COMPILER_FLAGS "@CMAKE_CXX_FLAGS@"

#define PRISMS_PF_BUILD_TYPE "@CMAKE_BUILD_TYPE@"

#define PRISMS_PF_MPI_CXX_COMPILER "@MPI_CXX_COMPILER@"
#define PRISMS_PF_MPI_CXX_VERSION "@MPI_CXX_VERSION@"

#define PRISMS_PF_DEAL_II_VERSION "@DEAL_II_VERSION@"
#define PRISMS_PF_DEAL_II_VERSION_MAJOR @DEAL_II_VERSION_MAJOR @
#define PRISMS_PF_DEAL_II_VERSION_MINOR @DEAL_II_VERSION_MINOR @
#define PRISMS_PF_DEAL_II_VERSION_SUBMINOR @DEAL_II_VERSION_SUBMINOR @

// Macros for opening and closing prisms namespace
#define PRISMS_PF_BEGIN_NAMESPACE \
  namespace prisms                \
  {
#define PRISMS_PF_END_NAMESPACE }

// Replacement macros for deal.II that do nothing
#ifndef PRISMS_PF_GPU
#  define DEAL_II_HOST_DEVICE
#  define DEAL_II_HOST_DEVICE_ALWAYS_INLINE
#endif

// Replacement macros for caliper that do nothing
#ifndef PRISMS_PF_WITH_CALIPER
#  define CALI_MARK_BEGIN(region_name)
#  define CALI_MARK_END(region_name)
#endif

// NOLINTEND(cppcoreguidelines-macro-usage)
