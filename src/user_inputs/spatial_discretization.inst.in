for ( dimension : SPACE_DIMENSIONS)
  {
    template class Mesh<dimension>;
    template class RectangularMesh<dimension>;
    template class SphericalMesh<dimension>;
    template class SpatialDiscretization<dimension>;
  }

for ( dimension : SPACE_DIMENSIONS; number : REAL_SCALARS)
  {
    template void Mesh<dimension>::mark_periodic(const dealii::DoFHandler<dimension> &dof_handler, dealii::AffineConstraints<number> &constraints);
  }
