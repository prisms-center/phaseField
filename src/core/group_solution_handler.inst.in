for ( dimension : SPACE_DIMENSIONS; number : REAL_SCALARS)
  {
    template class SolutionLevel<dimension, number>;
  }
for ( dimension : SPACE_DIMENSIONS; number : REAL_SCALARS)
  {
    template class GroupSolutionHandler<dimension, number>;
  }
for ( dimension : SPACE_DIMENSIONS; degree : ELEMENT_DEGREE; number : REAL_SCALARS)
  {
    template void GroupSolutionHandler<dimension, number>::init(
      const DoFManager<dimension, degree>                &dof_manager,
      const ConstraintManager<dimension, degree, number> &constraint_manager,
      unsigned int                                        num_old_saved);
  }
for ( dimension : SPACE_DIMENSIONS; degree : ELEMENT_DEGREE; number : REAL_SCALARS)
  {
    template void GroupSolutionHandler<dimension, number>::reinit(
      const DoFManager<dimension, degree>                &dof_manager,
      const ConstraintManager<dimension, degree, number> &constraint_manager);
  }
