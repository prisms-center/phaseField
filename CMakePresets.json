          "name": "release",
          "type": "configure"
        },
        {
          "name": "release",
          "type": "build"
        }
      ]
    },
    {
      "name": "debugrelease",
      "steps": [
        {
          "name": "debugrelease",
          "type": "configure"
        },
        {
          "name": "debugrelease",
          "type": "build"
        }
      ]
    },
    {
      "name": "docs",
      "steps": [
        {
          "name": "docs",
          "type": "configure"
        },
        {
          "name": "docs",
          "type": "build"
        }
      ]
    }
  ]
