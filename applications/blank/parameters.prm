subsection Rectangular mesh
  set x size = 1.0
  set y size = 1.0
  set z size = 1.0
  set x subdivisions = 1
  set y subdivisions = 1
  set z subdivisions = 1
end

set global refinement = 1

set time step = 1.0
set number steps = 1

subsection output
  set condition = EQUAL_SPACING
  set number = 1
end

