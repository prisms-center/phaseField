@PACKAGE_INIT@

# Dependencies
include(CMakeFindDependencyMacro)

# MPI
find_dependency(MPI REQUIRED COMPONENTS CXX)

# deal.II
set(DEAL_II_DIR "@DEAL_II_DIR@")
find_dependency(deal.II REQUIRED HINTS ${DEAL_II_DIR} $ENV{DEAL_II_DIR})

# Exported targets
include(${CMAKE_CURRENT_LIST_DIR}/prisms_pf_targets.cmake)

check_required_components(prisms_pf)
