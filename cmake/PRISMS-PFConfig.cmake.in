@PACKAGE_INIT@

# PRISMS-PF build types. This lets us know whether we have standard
# CMake build types or deal.II's DebugRelease
set(PRISMS_PF_BUILD_TYPE "@CMAKE_BUILD_TYPE@")

# Dependencies
include(CMakeFindDependencyMacro)

# Path for other vendored dependencies and put them in the front
# of the CMake prefix path
get_filename_component(_pkg_prefix
    "${CMAKE_CURRENT_LIST_DIR}/../../.."
    ABSOLUTE)

# libassert
# TODO: Unify behavior of libassert between "DebugRelease" and "Debug"/"Release"
if(PRISMS_PF_BUILD_TYPE STREQUAL "DebugRelease")
  if(CMAKE_BUILD_TYPE STREQUAL "Debug")
    list(PREPEND CMAKE_PREFIX_PATH "${_pkg_prefix}/vendored/libassert-debug")
    find_dependency(libassert)
  else()
    list(PREPEND CMAKE_PREFIX_PATH "${_pkg_prefix}/vendored/libassert")
    find_dependency(libassert)
  endif()
else()
  list(PREPEND CMAKE_PREFIX_PATH "${_pkg_prefix}")
  find_dependency(libassert)
endif()

# MPI
find_dependency(MPI COMPONENTS CXX)

# deal.II
find_dependency(deal.II HINTS ${DEAL_II_DIR} $ENV{DEAL_II_DIR})

# Caliper
find_package(caliper HINTS ${CALIPER_DIR} $ENV{CALIPER_DIR})

# Exported targets
include(${CMAKE_CURRENT_LIST_DIR}/prisms_pf_targets.cmake)

check_required_components(prisms_pf)
