@PACKAGE_INIT@

# PRISMS-PF build types. This lets us know whether we have standard
# CMake build types or deal.II's DebugRelease
set(PRISMS_PF_BUILD_TYPE "@CMAKE_BUILD_TYPE@")

# PRISMS-PF Vendored packages. This lets us know where to search when
# finding dependencies
set(PRISMS_PF_VENDORED_PACKAGES "@PRISMS_PF_VENDORED_PACKAGES@")

# Dependencies
include(CMakeFindDependencyMacro)

# Path for other vendored dependencies
get_filename_component(_pkg_prefix
  "${CMAKE_CURRENT_LIST_DIR}/../../../vendored"
  ABSOLUTE
)

# Helper function for adding vendored dependency static libraries.
# This function mirrors how we declare the imported libraries in 
# the first place.
# NOTE: I'm not a fan of this, but oh well
function(_prisms_pf_import_archive TARGET_NAME PREFIX_DIR ARCHIVE_NAME)
  if(TARGET ${TARGET_NAME})
    return()
  endif()
  add_library(${TARGET_NAME} STATIC IMPORTED GLOBAL)
  set_target_properties(${TARGET_NAME}
    PROPERTIES
      IMPORTED_LOCATION
        "${PREFIX_DIR}/lib/${ARCHIVE_NAME}.a"
  )
  if(IS_DIRECTORY "${PREFIX_DIR}/include")
    set_target_properties(${TARGET_NAME}
      PROPERTIES
        INTERFACE_INCLUDE_DIRECTORIES
          "${PREFIX_DIR}/include"
    )
  endif()
endfunction()

# libassert (always vendored)
# For libassert we also have to find its dependencies
find_dependency(Threads)
if("libassert" IN_LIST PRISMS_PF_VENDORED_PACKAGES)
  # dwarf
  _prisms_pf_import_archive(
    imported_dwarf
    "${_pkg_prefix}/libassert"
    libdwarf
  )
  # zstd
  _prisms_pf_import_archive(
    imported_zstd
    "${_pkg_prefix}/libassert"
    libzstd
  )
  # cpptrace
  _prisms_pf_import_archive(
    imported_cpptrace
    "${_pkg_prefix}/libassert"
    libcpptrace
  )
  set_target_properties(imported_cpptrace
    PROPERTIES
      INTERFACE_LINK_LIBRARIES
        "imported_dwarf;imported_zstd;Threads::Threads;${CMAKE_DL_LIBS}"
  )
  # libassert
  _prisms_pf_import_archive(
    imported_libassert
    "${_pkg_prefix}/libassert"
    libassert
  )
  set_target_properties(imported_libassert
    PROPERTIES
      INTERFACE_LINK_LIBRARIES
        imported_cpptrace
  )
  # dwarf debug
  _prisms_pf_import_archive(
    imported_dwarf_debug
    "${_pkg_prefix}/libassert_debug"
    libdwarf
  )
  # zstd debug
  _prisms_pf_import_archive(
    imported_zstd_debug
    "${_pkg_prefix}/libassert_debug"
    libzstd
  )
  # cpptrace debug
  _prisms_pf_import_archive(
    imported_cpptrace_debug
    "${_pkg_prefix}/libassert_debug"
    libcpptrace
  )
  set_target_properties(imported_cpptrace_debug
    PROPERTIES
      INTERFACE_LINK_LIBRARIES
        "imported_dwarf_debug;imported_zstd_debug;Threads::Threads;${CMAKE_DL_LIBS}"
  )
  # libassert debug
  _prisms_pf_import_archive(
    imported_libassert_debug
    "${_pkg_prefix}/libassert_debug"
    libassert
  )
  set_target_properties(imported_libassert_debug
    PROPERTIES
      INTERFACE_LINK_LIBRARIES
        imported_cpptrace_debug
  )
endif()

# MPI
find_dependency(MPI COMPONENTS CXX)

# deal.II
find_dependency(deal.II HINTS ${DEAL_II_DIR} $ENV{DEAL_II_DIR})

# Caliper
find_package(caliper HINTS ${CALIPER_DIR} $ENV{CALIPER_DIR})

# Exported targets
include(${CMAKE_CURRENT_LIST_DIR}/prisms_pf_targets.cmake)

check_required_components(prisms_pf)
